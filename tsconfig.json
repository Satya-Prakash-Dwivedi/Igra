{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "rootDir": "./server",
    "outDir": "./dist",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": false
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules"]
}
